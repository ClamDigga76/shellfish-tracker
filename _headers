# Netlify headers for Shellfish Tracker (PWA-friendly)
# Keep HTML/manifest/SW fresh so updates are discovered, while allowing assets to cache.

/index.html
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0

/manifest.webmanifest
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0

/sw.js
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0

/legal/*
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0

/*
  Cache-Control: public, max-age=31536000, immutable
